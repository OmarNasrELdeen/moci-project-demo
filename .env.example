# Local SQL Server connection (source system for mock data + extraction)
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=MociSourceDB
SQLSERVER_DRIVER=ODBC Driver 17 for SQL Server

# Authentication: set to "yes" for Windows Auth (trusted connection),
# or "no" and provide SQLSERVER_USER / SQLSERVER_PASSWORD for SQL auth.
SQLSERVER_TRUSTED_CONNECTION=yes
SQLSERVER_USER=
SQLSERVER_PASSWORD=

# Mock data volumes
MOCK_CUSTOMERS_COUNT=50000
MOCK_PRODUCTS_COUNT=5000
MOCK_STORES_COUNT=200
MOCK_EMPLOYEES_COUNT=2000
MOCK_ORDERS_COUNT=5000000
MOCK_ORDER_ITEMS_MULTIPLIER=2
MOCK_BATCH_SIZE=100000
